<?xml version="1.0" encoding="utf-8"?>
<!-- Layout Paramètres : ScrollView avec nom, thème (CheckBox/Switch/RadioButton), clé API et bouton de sauvegarde -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/deep_night_slate">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Toolbar / Titre (si pas déjà géré par ActionBar) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="24dp"
            android:text="@string/settings_title"
            android:textColor="@color/elven_gold"
            android:textSize="24sp"
            android:textStyle="bold" />

        <!-- Section 1 : Profil Utilisateur -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="@string/settings_profile_section"
            android:textColor="@color/mystical_purple_light"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_username_label"
            android:textColor="@color/text_hint"
            android:textSize="12sp" />

        <EditText
            android:id="@+id/settings_edit_username"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="16dp"
            android:background="@color/surface_container"
            android:hint="@string/settings_username_hint"
            android:inputType="textPersonName"
            android:padding="12dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint" />

        <!-- Section 2 : Préférences -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="@string/settings_preferences_section"
            android:textColor="@color/mystical_purple_light"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- Switch pour Thème Sombre -->
        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/settings_switch_dark"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="8dp"
            android:text="@string/settings_dark_theme"
            android:textColor="@color/text_primary"
            app:thumbTint="@color/mystical_purple"
            app:trackTint="@color/surface_variant" />

        <!-- CheckBox pour les effets magiques -->
        <CheckBox
            android:id="@+id/settings_checkbox_effects"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="16dp"
            android:buttonTint="@color/elven_gold"
            android:text="@string/settings_magic_effects"
            android:textColor="@color/text_primary" />

        <!-- RadioGroup pour la faction préférée -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_faction_section"
            android:textColor="@color/text_hint"
            android:textSize="12sp" />

        <RadioGroup
            android:id="@+id/settings_radio_group_faction"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="16dp"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/settings_radio_elves"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:buttonTint="@color/elven_gold"
                android:text="@string/settings_faction_elves"
                android:textColor="@color/text_primary" />

            <RadioButton
                android:id="@+id/settings_radio_dwarves"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:buttonTint="@color/outline"
                android:text="@string/settings_faction_dwarves"
                android:textColor="@color/text_primary" />

            <RadioButton
                android:id="@+id/settings_radio_mordor"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:buttonTint="@color/mystical_purple"
                android:text="@string/settings_faction_mordor"
                android:textColor="@color/text_primary" />
        </RadioGroup>

        <!-- Section 3 : Configuration API TMDB -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="@string/settings_api_section"
            android:textColor="@color/mystical_purple_light"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_api_key_label"
            android:textColor="@color/text_hint"
            android:textSize="12sp" />

        <EditText
            android:id="@+id/settings_edit_api_key"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="24dp"
            android:background="@color/surface_container"
            android:hint="@string/settings_api_key_hint"
            android:inputType="textPassword"
            android:padding="12dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint" />

        <!-- Section 4 : Informations de version -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/settings_version"
            android:textColor="@color/text_hint"
            android:textSize="12sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:layout_marginBottom="24dp"
            android:text="Licence TP INF 392"
            android:textColor="@color/text_hint"
            android:textSize="10sp" />

        <!-- Bouton Sauvegarder -->
        <Button
            android:id="@+id/settings_btn_save"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:backgroundTint="@color/mystical_purple"
            android:text="@string/settings_save"
            android:textColor="@color/elven_gold"
            android:textSize="16sp"
            android:textStyle="bold" />

    </LinearLayout>
</ScrollView>
