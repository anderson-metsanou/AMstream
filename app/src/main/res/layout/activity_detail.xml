<?xml version="1.0" encoding="utf-8"?>
<!-- Layout Détail Film : ScrollView avec poster, infos TMDB, et formulaire personnel -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/deep_night_slate">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Toolbar -->
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar_detail"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/surface_container"
            android:elevation="4dp"
            app:navigationIcon="?attr/homeAsUpIndicator"
            app:popupTheme="@style/Theme.AMstream.Toolbar"
            app:title="@string/detail_title"
            app:titleTextColor="@color/elven_gold" />

        <!-- Poster du film -->
        <ImageView
            android:id="@+id/detail_poster"
            android:layout_width="200dp"
            android:layout_height="300dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="16dp"
            android:contentDescription="@string/detail_title"
            android:scaleType="centerCrop" />

        <!-- Titre du film -->
        <TextView
            android:id="@+id/detail_movie_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="16dp"
            android:gravity="center"
            android:textColor="@color/elven_gold"
            android:textSize="22sp"
            android:textStyle="bold" />

        <!-- Tableau de métadonnées TMDB (TableLayout) -->
        <TableLayout
            android:id="@+id/detail_metadata_table"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="16dp"
            android:background="@color/surface_container_high"
            android:padding="12dp"
            android:stretchColumns="1,3">

            <!-- Ligne 1 : Note TMDB | Date de sortie -->
            <TableRow android:padding="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/detail_tmdb_rating"
                    android:textColor="@color/text_hint"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/detail_tmdb_rating"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="16dp"
                    android:textColor="@color/elven_gold"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/detail_release_date"
                    android:textColor="@color/text_hint"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/detail_release_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />
            </TableRow>

            <!-- Ligne 2 : Langue | Popularité -->
            <TableRow android:padding="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/detail_language"
                    android:textColor="@color/text_hint"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/detail_language"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="16dp"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/detail_popularity"
                    android:textColor="@color/text_hint"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/detail_popularity"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />
            </TableRow>
        </TableLayout>

        <!-- Section Synopsis -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="20dp"
            android:layout_marginEnd="16dp"
            android:text="@string/detail_synopsis"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/detail_synopsis"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="16dp"
            android:lineSpacingExtra="4dp"
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />

        <!-- Séparateur -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="20dp"
            android:layout_marginEnd="16dp"
            android:background="@color/outline_variant" />

        <!-- Section personnelle : Ma Note & Avis -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="16dp"
            android:text="@string/detail_personal_section"
            android:textColor="@color/mystical_purple_light"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- Spinner pour le statut -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="12dp"
            android:text="@string/detail_status_label"
            android:textColor="@color/text_hint"
            android:textSize="12sp" />

        <Spinner
            android:id="@+id/detail_spinner_status"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="16dp"
            android:background="@color/surface_variant"
            android:entries="@array/status_array"
            android:padding="8dp" />

        <!-- RatingBar pour la note personnelle -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="12dp"
            android:text="@string/detail_rating_label"
            android:textColor="@color/text_hint"
            android:textSize="12sp" />

        <RatingBar
            android:id="@+id/detail_rating_bar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="4dp"
            android:numStars="5"
            android:progressTint="@color/elven_gold"
            android:rating="0"
            android:stepSize="0.5" />

        <!-- EditText pour l'avis écrit -->
        <EditText
            android:id="@+id/detail_review_edit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="16dp"
            android:background="@color/surface_variant"
            android:hint="@string/detail_review_hint"
            android:inputType="textMultiLine"
            android:minHeight="80dp"
            android:padding="12dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint" />

        <!-- Bouton pour la date de visionnage (ouvre DatePickerDialog) -->
        <Button
            android:id="@+id/detail_btn_date"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="16dp"
            android:backgroundTint="@color/surface_variant"
            android:text="@string/detail_select_date"
            android:textColor="@color/text_primary" />

        <!-- Bouton Ajouter/Modifier à ma collection -->
        <Button
            android:id="@+id/detail_btn_add"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_margin="16dp"
            android:backgroundTint="@color/mystical_purple"
            android:text="@string/detail_add_to_collection"
            android:textColor="@color/elven_gold"
            android:textSize="16sp"
            android:textStyle="bold" />

    </LinearLayout>
</ScrollView>
