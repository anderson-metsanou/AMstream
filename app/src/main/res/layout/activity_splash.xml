<?xml version="1.0" encoding="utf-8"?>
<!-- Layout Splash Screen : Logo central + texte de chargement -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/deep_night_slate"
    android:gravity="center"
    android:orientation="vertical">

    <!-- Logo de l'application -->
    <ImageView
        android:id="@+id/splash_logo"
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:contentDescription="@string/app_name"
        android:src="@drawable/ic_launcher" />

    <!-- Nom de l'application -->
    <TextView
        android:id="@+id/splash_app_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="@string/app_name"
        android:textColor="@color/elven_gold"
        android:textSize="36sp"
        android:textStyle="bold" />

    <!-- Sous-titre thématique -->
    <TextView
        android:id="@+id/splash_tagline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/app_tagline"
        android:textColor="@color/mystical_purple_light"
        android:textSize="16sp" />

    <!-- Texte de chargement -->
    <TextView
        android:id="@+id/splash_loading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        android:text="@string/splash_loading"
        android:textColor="@color/text_hint"
        android:textSize="14sp"
        android:textStyle="italic" />

</LinearLayout>
