<?xml version="1.0" encoding="utf-8"?>
<!-- Layout Collection : Toolbar + RecyclerView + FAB -->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/deep_night_slate">

    <!-- Toolbar avec titre et menu d'options -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar_collection"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/surface_container"
        android:elevation="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:popupTheme="@style/Theme.AMstream.Toolbar"
        app:title="@string/collection_title"
        app:titleTextColor="@color/elven_gold" />

    <!-- RecyclerView pour afficher les films de la collection -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_collection"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:padding="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar_collection" />

    <!-- Message affiché quand la collection est vide -->
    <TextView
        android:id="@+id/text_empty_collection"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="@string/collection_empty"
        android:textColor="@color/text_hint"
        android:textSize="16sp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar_collection" />

    <!-- FloatingActionButton pour accéder à la recherche -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_search"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:contentDescription="@string/menu_search"
        android:src="@android:drawable/ic_input_add"
        app:backgroundTint="@color/elven_gold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:tint="@color/deep_night_slate" />

</androidx.constraintlayout.widget.ConstraintLayout>
